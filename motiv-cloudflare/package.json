{
  "name": "motiv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "preview": "npx @cloudflare/next-on-pages",
    "deploy": "npx @cloudflare/next-on-pages && wrangler pages deploy .vercel/output/static",
    "d1:create": "wrangler d1 create motiv-db",
    "d1:migrate": "wrangler d1 execute motiv-db --file=./schema.sql",
    "d1:migrate:local": "wrangler d1 execute motiv-db --local --file=./schema.sql",
    "r2:create": "wrangler r2 bucket create motiv-uploads",
    "cf:types": "wrangler types"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "@cloudflare/next-on-pages": "^1.13.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@remotion/cli": "^4.0.438",
    "@remotion/motion-blur": "^4.0.438",
    "@remotion/noise": "^4.0.438",
    "@remotion/player": "^4.0.438",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "html2canvas-pro": "^2.0.2",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.0.1",
    "next": "14.2.18",
    "openai": "^6.32.0",
    "react": "^18",
    "react-dom": "^18",
    "remotion": "^4.0.438",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^3.99.0"
  }
}
